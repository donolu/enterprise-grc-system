DJANGO_SETTINGS_MODULE=app.settings.local
SECRET_KEY=replace-with-a-local-django-secret
DEBUG=1

POSTGRES_DB=grc
POSTGRES_USER=grc
POSTGRES_PASSWORD=replace-with-a-local-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://grc:replace-with-a-local-postgres-password@postgres:5432/grc
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Azurite (local)
STORAGE_BACKEND=azure
TENANT_STORAGE_PREFIX=tenant
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_BLOB_CONTAINER=tenant-docs

# S3-compatible alternative for local MinIO, Spaces or R2 testing
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_REGION=eu-west-2
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_ADDRESSING_STYLE=auto
OBJECT_STORAGE_CREATE_BUCKET=false

# Email (MailHog)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@local.grc
SITE_DOMAIN=localhost:8000

# ONLYOFFICE
ONLYOFFICE_PUBLIC_URL=http://localhost:8085
ONLYOFFICE_INTERNAL_URL=http://onlyoffice

# OpenSearch (optional)
SEARCH_URL=http://opensearch:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=replace-with-a-local-opensearch-password

# Tenancy
TENANCY_MODE=subdomain   # or header
TENANT_HEADER=X-Tenant-Id

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
METRICS_ENABLED=1
METRICS_BEARER_TOKEN=

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_FREE=
STRIPE_PRICE_BASIC=replace-with-stripe-basic-price-id
STRIPE_PRICE_ENTERPRISE=replace-with-stripe-enterprise-price-id
