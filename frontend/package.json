{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "generate:api-types": "openapi-typescript ../app/schema.yml -o src/lib/api/generated/schema.d.ts",
    "verify:api-types": "npm run generate:api-types && git diff --exit-code -- src/lib/api/generated/schema.d.ts"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.0.1",
    "@sentry/nextjs": "^10.66.0",
    "@tanstack/react-query": "^5.101.2",
    "antd": "^5.21.4",
    "axios": "^1.18.1",
    "dayjs": "^1.11.13",
    "next": "15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.20",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
