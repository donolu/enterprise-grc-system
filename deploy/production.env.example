DJANGO_SETTINGS_MODULE=app.settings.production
SECRET_KEY=replace-with-a-long-random-secret

DATABASE_URL=postgres://grc:replace-with-password@postgres:5432/grc
DIRECT_DATABASE_URL=
DATABASE_SSLMODE=require
POSTGRES_DB=grc
POSTGRES_USER=grc
POSTGRES_PASSWORD=replace-with-password
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

PUBLIC_HOSTNAME=grc.example.com
ADDITIONAL_HOSTS=
CORS_ALLOWED_ORIGINS=https://grc.example.com
CSRF_TRUSTED_ORIGINS=https://grc.example.com
SECURE_SSL_REDIRECT=true

# azure, s3, filesystem, or local
STORAGE_BACKEND=s3
TENANT_STORAGE_PREFIX=tenant

# S3-compatible storage: AWS S3, DigitalOcean Spaces, Cloudflare R2, MinIO.
OBJECT_STORAGE_BUCKET=axim-grc-documents
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_REGION=eu-west-2
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-key
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_ADDRESSING_STYLE=auto
OBJECT_STORAGE_CREATE_BUCKET=false

# Azure Blob remains supported.
AZURE_STORAGE_CONNECTION_STRING=

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=replace-with-email-user
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

METRICS_ENABLED=0
METRICS_BEARER_TOKEN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_ENTERPRISE=
